{
  "id": "swerpg",
  "title": "Star Wars Edge RPG",
  "description": "Enjoy thrilling adventures in the Star Wars™ galaxy with any or all of three different Star Wars roleplaying systems — Age of Rebellion, Edge of the Empire, and Force and Destiny.",
  "manifest": "#{MANIFEST}#",
  "download": "#{DOWNLOAD}#",
  "version": "#{VERSION}#",
  "url": "https://github.com/herveDarritchon/foundryvtt-swerpg",
  "bugs": "https://github.com/herveDarritchon/foundryvtt-swerpg/issues",
  "background": "systems/swerpg/assets/images/star-wars-edge.webp",
  "authors": [
    {
      "name": "Hervé Darritchon",
      "discord": "herveDarritchon#7262",
      "email": "herve.darritchon@gmail.com",
      "flags": {}
    }
  ],
  "flags": {
    "hotReload": {
      "extensions": ["less", "css", "hbs", "json"],
      "paths": ["lang/en.json", "styles", "templates"]
    }
  },
  "media": [
    {
      "type": "setup",
      "url": "systems/swerpg/assets/swerpg-logo.png",
      "thumbnail": "systems/swerpg/assets/swerpg-logo.png"
    }
  ],
  "compatibility": {
    "minimum": 14,
    "verified": 14.309,
    "maximum": 14
  },
  "license": "LICENSE",
  "esmodules": ["swerpg.mjs"],
  "styles": ["styles/swerpg.css"],
  "scripts": ["./vendors/jszip.min.js", "./vendors/xml2js.min.js"],
  "packs": [],
  "packFolders": [],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    },
    {
      "lang": "fr",
      "name": "French",
      "path": "lang/fr.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": ["details.biography.public", "details.biography.private", "details.biography.appearance"]
      },
      "adversary": {}
    },
    "Item": {
      "armor": {
        "htmlFields": ["description.public", "description.secret"]
      },
      "career": {
        "htmlFields": ["description"]
      },
      "duty": {
        "htmlFields": ["description"]
      },
      "gear": {
        "htmlFields": ["description.public", "description.secret"]
      },
      "obligation": {
        "htmlFields": ["description"]
      },
      "specialization": {
        "htmlFields": ["description"]
      },
      "species": {
        "htmlFields": ["description"]
      },
      "talent": {
        "htmlFields": ["description"]
      },
      "weapon": {
        "htmlFields": ["description.public", "description.secret"]
      },
      "motivation-category": {
        "htmlFields": ["description"]
      },
      "motivation": {
        "htmlFields": ["description"]
      },
      "specialization-tree": {
        "htmlFields": ["description"]
      }
    },
    "JournalEntryPage": {
      "skill": {}
    }
  },
  "grid": {
    "type": 1,
    "distance": 5,
    "units": "ft",
    "diagonals": 1
  },
  "socket": true,
  "primaryTokenAttribute": "resources.wounds",
  "secondaryTokenAttribute": "resources.strain"
}
