<section class="tab secondary {{tabs.talents.id}} flexcol scrollable {{tabs.talents.cssClass}}"
         data-tab="{{tabs.talents.id}}" data-group="{{tabs.talents.group}}">

    {{!-- XP panel (seule la progression XP, calquée sur skills.hbs) --}}
    <div class="skills-xp-panel swerpg-holo-panel talents-xp-panel">
        <div class="panel-header">
            <h3 class="panel-title">⚙️ {{localize "ACTOR.SKILL_EXPERIENCE_STATUS"}}</h3>
        </div>
        <div class="panel-body">
            <div class="rows">
                <div class="row xp-row">
                    <div class="label" title="{{localize "ACTOR.FREE_SKILLS.XPTooltip"}}">{{localize "ACTOR.FREE_SKILLS.XPProgressLabel"}}</div>
                    <div class="meter xp-bar"
                         role="progressbar"
                         aria-valuemin="0"
                         aria-valuemax="{{progression.experience.total}}"
                         aria-valuenow="{{progression.experience.spent}}"
                         aria-valuetext="{{progression.experience.spent}} / {{progression.experience.total}}"
                         data-xp-spent="{{progression.experience.spent}}"
                         data-xp-total="{{progression.experience.total}}"
                         data-tooltip="{{progression.experience.spent}} {{localize 'ACTOR.FREE_SKILLS.XPSpentShort'}} / {{progression.experience.total}}" data-tooltip-direction="DOWN"
                         style="--xp-percent: {{progression.experience.percent}};">
                        <div class="xp-fill" aria-hidden="true"></div>
                        <div class="xp-center-label">{{progression.experience.available}} XP</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{!-- Barre de filtres pour les talents --}}
    <div class="talent-filters swerpg-holo-panel">
        <div class="panel-body filters-body">
            <div class="filter-buttons">
                <button class="filter-btn active" data-action="talentFilter" data-filter="all">TOUS</button>
                <button class="filter-btn" data-action="talentFilter" data-filter="active">ACTIFS</button>
                <button class="filter-btn" data-action="talentFilter" data-filter="passive">PASSIFS</button>
                <button class="filter-btn" data-action="talentFilter" data-filter="ranked">CLASSÉS</button>
            </div>
        </div>
    </div>

    {{!-- Conteneur de cartes de talents --}}
    <div class="talent-cards">
        {{#each talents as |talent s|}}
            {{!-- Construire un attribut data-tags (labels séparés par des virgules) pour le filtrage côté client --}}
            <div class="talent-card-wrapper" data-item-id="{{talent.id}}" data-tags="{{#each talent.tags}}{{label}}{{#unless @last}},{{/unless}}{{/each}}">
                {{> "systems/swerpg/templates/sheets/partials/talent-card.hbs" talent=talent}}
            </div>
        {{/each}}
    </div>

    <div class="talent-actions swerpg-holo-panel">
        <div class="panel-body">
            <button class="button large" data-action="talentAdd">+ AJOUTER UN TALENT</button>
        </div>
    </div>

</section>
