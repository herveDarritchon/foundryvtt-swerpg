<section class="tab secondary {{tabs.skills.id}} flexcol {{tabs.skills.cssClass}} scrollable"
         data-tab="{{tabs.skills.id}}" data-group="{{tabs.skills.group}}">

    {{!-- Nouveau bloc : XP / Skills holographique --}}
    <div class="skills-xp-panel swerpg-holo-panel">
        <div class="panel-header">
            <h3 class="panel-title">⚙️ {{localize "ACTOR.SKILL_EXPERIENCE_STATUS"}}</h3>
        </div>
        <div class="panel-body">
            <div class="rows">
                <div class="row skill-row">
                    <div class="label">{{localize "ACTOR.FREE_SKILLS.CareerSkills"}}</div>
                    <div class="meter skill-pips" aria-hidden="true" data-pips-type="career">
                        <div class="pips" role="list" data-tooltip="({{math (subtract progression.freeSkillRanks.career.gained progression.freeSkillRanks.career.available)}} / {{progression.freeSkillRanks.career.gained}})">
                            {{#each progression.freeSkillRanks.career.pips}}
                              <span class="pip {{#if active}}active{{else}}used{{/if}}" data-index="{{index}}" role="listitem" aria-checked="{{#if active}}true{{else}}false{{/if}}"></span>
                            {{/each}}
                        </div>
                    </div>
                    <div class="value remaining career muted-remaining">{{progression.freeSkillRanks.career.available}} {{localize "ACTOR.FREE_SKILLS.remaining"}}</div>
                </div>

                <div class="row skill-row">
                    <div class="label">{{localize "ACTOR.FREE_SKILLS.SpecializationSkills"}}</div>
                    <div class="meter skill-pips" aria-hidden="true" data-pips-type="specialization">
                        <div class="pips" role="list" data-tooltip="({{math (subtract progression.freeSkillRanks.specialization.gained progression.freeSkillRanks.specialization.available)}} / {{progression.freeSkillRanks.specialization.gained}})">
                            {{#each progression.freeSkillRanks.specialization.pips}}
                              <span class="pip {{#if active}}active{{else}}used{{/if}}" data-index="{{index}}" role="listitem" aria-checked="{{#if active}}true{{else}}false{{/if}}"></span>
                            {{/each}}
                        </div>
                    </div>
                    <div class="value remaining spec muted-remaining">{{progression.freeSkillRanks.specialization.available}} {{localize "ACTOR.FREE_SKILLS.remaining"}}</div>
                </div>

                {{!-- Micro-labels under pips to make "chosen / total" explicit --}}
                {{!-- Résumé déplacé à côté des pips pour lisibilité; ancienne ligne de résumé supprimée --}}

                <div class="row xp-row">
                    {{!-- Changed label to be clearer about the bar meaning --}}
                    <div class="label" title="{{localize "ACTOR.FREE_SKILLS.XPTooltip"}}">{{localize "ACTOR.FREE_SKILLS.XPProgressLabel"}}</div>
                    <div class="meter xp-bar"
                         role="progressbar"
                         aria-valuemin="0"
                         aria-valuemax="{{progression.experience.total}}"
                         aria-valuenow="{{progression.experience.spent}}"
                         aria-valuetext="{{progression.experience.spent}} / {{progression.experience.total}}"
                         data-xp-spent="{{progression.experience.spent}}"
                         data-xp-total="{{progression.experience.total}}"
                         data-tooltip="{{progression.experience.spent}} {{localize 'ACTOR.FREE_SKILLS.XPSpentShort'}} / {{progression.experience.total}}" data-tooltip-direction="DOWN"
                         style="--xp-percent: {{progression.experience.percent}};">
                        <div class="xp-fill" aria-hidden="true"></div>
                        <!-- Center label made explicit: "spent / total" and a clearer text for assistive tech -->
                        <div class="xp-center-label">{{progression.experience.available}} XP</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="skills-wrapper">

        <section class="general-skills">
            <h4>{{localize "ACTOR.FREE_SKILLS.GeneralSkills"}}</h4>
            {{#each skills.general as |skill|}}
                {{> "systems/swerpg/templates/sheets/partials/character-skill.hbs" skill}}
            {{/each}}
        </section>

        <section class="non-general-skills">
            <div class="combat-skills">
                <h4>{{localize "ACTOR.FREE_SKILLS.CombatSkills"}}</h4>
                {{#each skills.combat as |skill|}}
                    {{> "systems/swerpg/templates/sheets/partials/character-skill.hbs" skill}}
                {{/each}}
            </div>
            <div class="knowledge-skills">
                <h4>{{localize "ACTOR.FREE_SKILLS.LoreSkills"}}</h4>
                {{#each skills.knowledge as |skill|}}
                    {{> "systems/swerpg/templates/sheets/partials/character-skill.hbs" skill}}
                {{/each}}
            </div>
        </section>


    </div>

    {{!--
