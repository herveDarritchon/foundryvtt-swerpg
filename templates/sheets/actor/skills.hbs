<section class="tab secondary scrollable {{tabs.skills.id}} flexcol {{tabs.skills.cssClass}} scrollable"
         data-tab="{{tabs.skills.id}}" data-group="{{tabs.skills.group}}">

    <div class="skills-wrapper">

        <section class="general-skills">
            <h4>{{localize "SKILL.CATEGORY.EXPLORATION.label"}}</h4>
            {{#each skills.general as |skill|}}
                {{> "systems/swerpg/templates/sheets/partials/character-skill.hbs" skill}}
            {{/each}}
        </section>

        <section class="non-general-skills">
            <div class="knowledge-skills">
                <h4>{{localize "SKILL.CATEGORY.KNOWLEDGE.label"}}</h4>
                {{#each skills.combat as |skill|}}
                    {{> "systems/swerpg/templates/sheets/partials/character-skill.hbs" skill}}
                {{/each}}
            </div>
            <div class="combat-skills">
                <h4>{{localize "SKILL.CATEGORY.SOCIAL.label"}}</h4>
                {{#each skills.knowledge as |skill|}}
                    {{> "systems/swerpg/templates/sheets/partials/character-skill.hbs" skill}}
                {{/each}}
            </div>
        </section>

    </div>
</section>
