<section class="tab secondary {{tabs.skills.id}} flexcol {{tabs.skills.cssClass}} scrollable"
         data-tab="{{tabs.skills.id}}" data-group="{{tabs.skills.group}}">

    {{!-- Nouveau bloc : XP / Skills holographique --}}
    <div class="skills-xp-panel swerpg-holo-panel">
        <div class="panel-header">
            <h3 class="panel-title">⚙️ SKILL & EXPERIENCE STATUS</h3>
        </div>
        <div class="panel-body">
            <div class="rows">
                <div class="row skill-row">
                    <div class="label">Career Skills</div>
                    <div class="meter skill-pips" aria-hidden="true">
                        <div class="pips">
                            {{#each progression.freeSkillRanks.career.pips}}
                              <span class="pip {{#if active}}active{{/if}}" data-index="{{index}}"></span>
                            {{/each}}
                        </div>
                    </div>
                    <div class="value remaining career">{{progression.freeSkillRanks.career.available}} remaining</div>
                </div>

                <div class="row skill-row">
                    <div class="label">Spec. Skills</div>
                    <div class="meter skill-pips" aria-hidden="true">
                        <div class="pips">
                            {{#each progression.freeSkillRanks.specialization.pips}}
                              <span class="pip {{#if active}}active{{/if}}" data-index="{{index}}"></span>
                            {{/each}}
                        </div>
                    </div>
                    <div class="value remaining spec">{{progression.freeSkillRanks.specialization.available}} remaining</div>
                </div>

                <div class="row xp-row">
                    <div class="label">XP Spent</div>
                    <div class="meter xp-bar" title="{{progression.experience.spent}} / {{progression.experience.total}}"
                         style="--xp-percent: {{progression.experience.percent}};">
                        <div class="xp-fill"></div>
                    </div>
                    <div class="value xp-numbers">{{progression.experience.spent}} / {{progression.experience.total}}</div>
                </div>

                <div class="row xp-available-row">
                    <div class="label">XP Available</div>
                    <div class="value xp-available"><span class="icon hex"></span> <span class="xp-amount">{{progression.experience.available}}</span></div>
                </div>
            </div>
        </div>
    </div>

    <div class="skills-wrapper">

        <section class="general-skills">
            <h4>General Skills</h4>
            {{#each skills.general as |skill|}}
                {{> "systems/swerpg/templates/sheets/partials/character-skill.hbs" skill}}
            {{/each}}
        </section>

        <section class="non-general-skills">
            <div class="combat-skills">
                <h4>Combat Skills</h4>
                {{#each skills.combat as |skill|}}
                    {{> "systems/swerpg/templates/sheets/partials/character-skill.hbs" skill}}
                {{/each}}
            </div>
            <div class="knowledge-skills">
                <h4>Lore Skills</h4>
                {{#each skills.knowledge as |skill|}}
                    {{> "systems/swerpg/templates/sheets/partials/character-skill.hbs" skill}}
                {{/each}}
            </div>
        </section>


    </div>

    {{!--
        {{#each skillCategories as |category catId|}}
        <div class="sheet-section item-section flexcol">
            <h3 class="section-header">{{category.label}} Skills</h3>
            <ol class="items-list skills-list" style="--skill-color:{{category.color.css}}">
                {{#each category.skills as |skill skillId|}}
                <li class="skill line-item {{skill.css}}" data-skill="{{skillId}}">
                    <img class="icon" src="{{skill.icon}}" alt="{{skill.name}}">
                    <div class="title">
                        <h4 data-tooltip="Roll Check" data-action="skillRoll"><a>{{skill.name}}</a></h4>
                    </div>
                    <div class="tags">
                        {{#each skill.rankTags as |tag|}}<span class="rank tag">{{tag}}</span>{{/each}}
                        {{#each skill.abilityAbbrs}}<span class="attribute tag">{{this}}</span>{{/each}}
                    </div>
                    <div class="bonus flexrow">
                        <span class="value hex {{skill.hexClass}}" data-tooltip="{{skill.tooltips.value}}">{{numberFormat skill.score sign=true}}</span>
                        <span class="passive" data-tooltip="Passive: {{skill.tooltips.passive}}">{{skill.passive}}</span>
                    </div>
                    <div class="ranks flexrow">
