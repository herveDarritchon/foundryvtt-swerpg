{{log "talent" talent}}
<article class="swerpg-talent-card swerpg-holo-panel {{talent.cssClass}}" data-item-id="{{talent.id}}">
    <div class="card-inner">
        <header class="card-header">
            <div class="header-left">
                <h3 class="talent-title" title="{{talent.name}}">{{talent.name}}</h3>
                <div class="card-tags">
                    {{#each talent.tags as |tag|}}
                        <span class="pill {{tag.cssClass}}" data-tag="{{tag.cssClass}}">{{tag.label}}</span>
                    {{/each}}
                    {{#if talent.rank}}
                        <span class="pill tag-rank" data-tag="rank-{{talent.row}}">RANG {{talent.row}}</span>
                    {{/if}}
                </div>
            </div>
        </header>

        <div class="card-body">
            {{#if talent.description}}
                <div class="talent-desc">{{{talent.description}}}</div>
            {{else}}
                <div class="talent-desc">—</div>
            {{/if}}
        </div>

        <footer class="card-footer">
            <div class="footer-left">
                <div class="talent-origin">{{#if talent.origin}}&lt;{{talent.origin}}&gt;{{/if}}</div>
            </div>
            <div class="talent-meta footer-right">
                {{!-- Display cost: prefer cost on last rank if rank is array; otherwise use talent.rank.cost; fallback to talent.cost --}}
                {{#if talent.rank}}
                    {{#if talent.rank.length}}
                        {{#each talent.rank as |r|}}
                            {{#if @last}}
                                {{#if r.cost}}<span class="cost">{{r.cost}} XP</span>{{else if talent.cost}}
                                    <span class="cost">{{talent.cost}} XP</span>{{/if}}
                            {{/if}}
                        {{/each}}
                    {{else}}
                        {{#if talent.rank.cost}}<span class="cost">{{talent.rank.cost}} XP</span>{{else if talent.cost}}
                            <span class="cost">{{talent.cost}} XP</span>{{/if}}
                    {{/if}}
                {{else if talent.cost}}<span class="cost">{{talent.cost}} XP</span>{{/if}}

                <button class="button tiny meta-display" data-action="itemDisplay"
                        title="{{localize "TALENT.Display"}}">
                    <i class="icon fa-solid fa-display" aria-hidden="true"></i>
                    {{localize "TALENT.Display"}}
                </button>

                {{#unless talent.isFree}}
                    <button class="button tiny meta-delete" data-action="itemDelete"
                            title="{{localize "TALENT.Delete"}}">
                        <i class="icon fa-solid fa-trash" aria-hidden="true"></i>
                        {{localize "TALENT.Delete"}}
                    </button>
                {{/unless}}
            </div>
        </footer>
    </div>
</article>
