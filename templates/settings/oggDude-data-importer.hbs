<div class="standard-form oggDude-data-importer scrollable">
    <h2>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.title"}}</h2>
    <section class="form-group file-picker flexcol">
        <h4>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.message"}}</h4>
        <div class="form-fields flexrow">
            {{!-- Utilisation directe de zipFile (suppression de this.) pour compatibilité Handlebars Foundry v13 --}}
            {{#if zipFile}}
                <p>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.selectFile"}}</p>
                <p data-tooltip="{{zipFile.path}}"><i class="fa-solid fa-file"></i>{{zipFile.name}}</p>
            {{else}}
                <label for="oggdude-zip-file">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.selectFile"}}</label>
                <input id="oggdude-zip-file" type="file" name="oggdude-zip-file" accept=".zip" value="{{zipFile.path}}"
                       data-zip-file="{{zipFile}}"/>
            {{/if}}
        </div>
    </section>

    <section class="import-options flexcol">
        <div class="form-group">
            <label class="checkbox">
                <input type="checkbox" name="import-to-compendium" {{checked importToCompendium}} data-action="toggleImportToCompendiumAction"/>
                {{localize "SETTINGS.OggDudeDataImporter.loadWindow.importToCompendium"}}
            </label>
            <p class="notes">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.importToCompendiumHint"}}</p>
        </div>
    </section>

    <section class="domain-selection flexcol">
        <h4>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.selectDomains"}}</h4>
        <div class="form-group select-all">
            <label class="checkbox">
                <input type="checkbox" id="select-all-domains" {{checked allDomainsChecked}} {{#if domainSelectionDisabled}}disabled{{/if}} data-action="toggleAllDomainsAction"/>
                {{localize "SETTINGS.OggDudeDataImporter.loadWindow.selectAllDomains"}}
            </label>
        </div>
        <div class="domains flexcol">
            {{!-- Suppression de this. pour chaque domaine --}}
            {{#each domains as |domain|}}
                <div class="domain{{#if ../domainSelectionDisabled}} not-allowed{{/if}}">
                    <label data-action="toggleDomainAction"
                           data-domain-checked="{{domain.checked}}"
                           data-domain-name="{{domain.id}}">
                        <input id="{{domain.id}}" type="checkbox" {{#if domain.checked}}checked{{/if}} {{#if
                                ../domainSelectionDisabled}}disabled{{/if}}>
                        <span>{{localize domain.label}}</span>
                    </label>
                </div>
            {{/each}}
        </div>
    </section>

    <section class="actions flexrow">
        <div class="load-button{{#if loadButtonDisabled}} not-allowed{{/if}}">
            <button type="button" class="control reset-button" data-action="loadAction"
                    {{#if loadButtonDisabled}}disabled{{/if}}>
                <i class="fa-solid fa-jedi"></i>
                {{localize "SETTINGS.OggDudeDataImporter.loadWindow.load"}}
            </button>
        </div>
        <div class="preload-button{{#if loadButtonDisabled}} not-allowed{{/if}}">
            <button type="button" class="control" data-action="preloadAction" {{#if loadButtonDisabled}}disabled{{/if}}>
                <i class="fa-solid fa-eye"></i>
                {{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.title"}}
            </button>
        </div>
        <button type="button" class="control reset-button" data-action="resetAction">
            <i class="fa-solid fa-refresh"></i>
            {{localize "SETTINGS.OggDudeDataImporter.loadWindow.reset"}}
        </button>
    </section>

    <section class="import-progress-bar flexcol" aria-labelledby="import-progress-bar-heading">
    {{!-- Jauge de progression globale des domaines importés (accessible) --}}
    <h4 id="import-stats-heading">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.progress-bar.title"}}</h4>
    <div class="import-progress-global" role="progressbar"
         aria-label="{{localize 'SETTINGS.OggDudeDataImporter.loadWindow.progress.global'}}"
         aria-valuemin="0" aria-valuemax="{{progress.total}}" aria-valuenow="{{progress.processed}}">
        <div class="bar" style="width: {{progressPercentDomains}}%"></div>
        <span class="sr-only">{{progress.processed}} / {{progress.total}}</span>
    </div>
    </section>

        {{!-- Résumé compact post-import --}}
        {{#if importSummary}}
            <section class="import-summary sw-panel" aria-labelledby="import-summary-heading">
                <h4 id="import-summary-heading">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.summary.title"}}</h4>
                <ul class="summary" role="list">
                    <li><strong>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.metrics.duration"}}:</strong> {{importSummary.overallDuration}}</li>
                    <li><strong>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.metrics.processed"}}:</strong> {{importSummary.totalProcessed}}</li>
                    <li><strong>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.metrics.errorRate"}}:</strong> {{importSummary.errorRate}}</li>
                    <li><strong>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.metrics.itemsPerSecond"}}:</strong> {{importSummary.itemsPerSecond}}</li>
                </ul>
            </section>
        {{/if}}

        {{!-- Section repliable Statistiques --}}
        {{#if hasStats}}
        <details class="import-stats sw-collapsible" id="import-stats-section" {{#if showStats}}open{{/if}}>
            <summary data-action="toggleStatsAction" aria-controls="import-stats-section" aria-expanded="{{showStats}}">
                <i class="fa-solid fa-chart-simple"></i> {{localize "SETTINGS.OggDudeDataImporter.loadWindow.stats.title"}}
            </summary>
            <table class="stats-table" role="table" aria-describedby="import-stats-section">
                <thead>
                <tr>
                    <th scope="col">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.stats.status.title"}}</th>
                    <th scope="col">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.stats.domain"}}</th>
                    <th scope="col">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.stats.total"}}</th>
                    <th scope="col">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.stats.imported"}}</th>
                    <th scope="col">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.stats.rejected"}}</th>
                    <th scope="col">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.stats.duration"}}</th>
                </tr>
                </thead>
                <tbody>
                {{#each statsTableRows as |row|}}
                    <tr>
                        <td class="{{row.status.class}}" aria-label="{{localize row.status.labelI18n}}"><i class="fa-solid fa-circle" aria-hidden="true"></i></td>
                        <th scope="row">{{localize row.labelI18n}}</th>
                        <td>{{row.stats.total}}</td>
                        <td>{{row.stats.imported}}</td>
                        <td>{{row.stats.rejected}}</td>
                        <td>{{row.duration}}</td>
                    </tr>
                {{/each}}
                </tbody>
            </table>
        </details>
        {{/if}}

        {{!-- Section repliable Métriques --}}
        {{#if hasMetrics}}
        <details class="import-metrics sw-collapsible" id="import-metrics-section" {{#if showMetrics}}open{{/if}}>
            <summary data-action="toggleMetricsAction" aria-controls="import-metrics-section" aria-expanded="{{showMetrics}}">
                <i class="fa-solid fa-gauge-high"></i> {{localize "SETTINGS.OggDudeDataImporter.loadWindow.metrics.title"}}
            </summary>
            <ul class="metrics" role="list">
                <li><strong>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.metrics.duration"}}:</strong> {{importMetricsFormatted.overallDuration}}</li>
                <li><strong>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.metrics.errorRate"}}:</strong> {{importMetricsFormatted.errorRate}}</li>
                <li><strong>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.metrics.itemsPerSecond"}}:</strong> {{importMetricsFormatted.itemsPerSecond}}</li>
                <li><strong>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.metrics.archiveSize"}}:</strong> {{importMetricsFormatted.archiveSize}}</li>
                <li><strong>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.metrics.processed"}}:</strong> {{importMetricsFormatted.totalProcessed}}</li>
            </ul>
        </details>
        {{/if}}

        {{!-- Section repliable Prévisualisation --}}
        {{#if hasPreview}}
        <details class="preview-section sw-collapsible" id="preview-section" {{#if showPreview}}open{{/if}}>
            <summary data-action="togglePreviewAction" aria-controls="preview-section" aria-expanded="{{showPreview}}">
                <i class="fa-solid fa-eye"></i> {{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.title"}}
            </summary>
            <div class="preview-controls flexrow" role="group"
                     aria-label="{{localize 'SETTINGS.OggDudeDataImporter.loadWindow.preview.filters'}}">
                <label>
                    <span>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.domain"}}</span>
                    <select name="preview-domain"
                                    aria-label="{{localize 'SETTINGS.OggDudeDataImporter.loadWindow.preview.domain'}}">
                        <option value="all">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.domainAll"}}</option>
                        {{#each domains as |domain|}}
                            <option value="{{domain.id}}">{{localize domain.label}}</option>
                        {{/each}}
                    </select>
                </label>
                <label>
                    <span>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.text"}}</span>
                    <input type="text" name="preview-text"
                                 placeholder="{{localize 'SETTINGS.OggDudeDataImporter.loadWindow.preview.textPlaceholder'}}"/>
                </label>
                <label>
                    <span>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.category"}}</span>
                    <select name="preview-category"
                                    aria-label="{{localize 'SETTINGS.OggDudeDataImporter.loadWindow.preview.category'}}">
                        <option value="all">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.categoryAll"}}</option>
                        {{#each categoryOptions as |opt|}}
                            <option value="{{opt.value}}">{{opt.label}}</option>
                        {{/each}}
                    </select>
                </label>
                <label>
                    <span>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.weaponType"}}</span>
                    <select name="preview-weaponType"
                                    aria-label="{{localize 'SETTINGS.OggDudeDataImporter.loadWindow.preview.weaponType'}}">
                        <option value="all">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.weaponTypeAll"}}</option>
                        {{#each weaponTypeOptions as |opt|}}
                            <option value="{{opt}}">{{opt}}</option>
                        {{/each}}
                    </select>
                </label>
            </div>
            {{#if preview.hasData}}
                <table class="preview-table" role="table" aria-describedby="preview-section">
                    <thead>
                    <tr>
                        <th scope="col">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.colName"}}</th>
                        <th scope="col">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.colType"}}</th>
                        <th scope="col">{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.colExists"}}</th>
                    </tr>
                    </thead>
                    <tbody>
                    {{#each preview.items as |item|}}
                        <tr>
                            <td>{{item.name}}</td>
                            <td>{{item.type}}</td>
                            <td>
                                {{#if item.exists}}
                                    <span class="exists" aria-label="{{localize 'SETTINGS.OggDudeDataImporter.loadWindow.preview.exists'}}">✔</span>
                                {{else}}
                                    <span class="new" aria-label="{{localize 'SETTINGS.OggDudeDataImporter.loadWindow.preview.new'}}">＋</span>
                                {{/if}}
                            </td>
                        </tr>
                    {{/each}}
                    </tbody>
                </table>
                <div class="pagination" role="navigation"
                         aria-label="{{localize 'SETTINGS.OggDudeDataImporter.loadWindow.preview.pagination'}}">
                    <span>{{preview.page}} / {{preview.totalPages}}</span>
                </div>
            {{else}}
                <p>{{localize "SETTINGS.OggDudeDataImporter.loadWindow.preview.noData"}}</p>
            {{/if}}
        </details>
        {{/if}}
</div>
